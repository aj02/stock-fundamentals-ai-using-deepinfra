# fundamentals-ai — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Every key listed here is read by docker-compose, the backend, or the frontend.
# Comments explain *why* the key exists, not just what it is.

# ────────────────────────────────────────────────────────────────────────────
# Postgres (used by the `postgres` service in docker-compose, and by the
# backend's SQLAlchemy/asyncpg connection string).
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=fundamentals
POSTGRES_PASSWORD=fundamentals
POSTGRES_DB=fundamentals_ai
POSTGRES_PORT=5432
# Connection string the backend will use. Inside docker-compose the host is
# the service name `postgres`; for local-dev outside compose use `localhost`.
DATABASE_URL=postgresql+asyncpg://fundamentals:fundamentals@postgres:5432/fundamentals_ai

# ────────────────────────────────────────────────────────────────────────────
# Redis (rate-limit windows, in-flight request dedup, short-term cache).
# ────────────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ────────────────────────────────────────────────────────────────────────────
# LLM provider toggle.
#   "anthropic" → Anthropic Claude (Sonnet for agents, Haiku for fast tasks)
#   "deepinfra" → DeepInfra-hosted open models (e.g. Kimi K2) via OpenAI-compat API
#
# The chosen provider's model MUST support OpenAI-style tool calling — every
# agent in this repo depends on it.
# ────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic

# ── Anthropic (used when LLM_PROVIDER=anthropic) ─────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Fallback (optional, only when LLM_PROVIDER=anthropic). If true and the
# Anthropic call fails, the agent retries via OpenAI.
LLM_FALLBACK_ENABLED=false
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4o

# ── DeepInfra (used when LLM_PROVIDER=deepinfra) ─────────────────────────────
# Exposes an OpenAI-compatible /v1/chat/completions endpoint, so PydanticAI's
# OpenAIModel works against it with a custom base_url.
#   - DEEPINFRA_API_KEY: copy from https://deepinfra.com/dash/api_keys
#   - DEEPINFRA_*_MODEL: confirm exact slugs at https://deepinfra.com/models
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_AGENT_MODEL=moonshotai/Kimi-K2.6
DEEPINFRA_FAST_MODEL=moonshotai/Kimi-K2.6

# ────────────────────────────────────────────────────────────────────────────
# Scraper ethics — Screener.in scraper rate limit + identifying User-Agent.
# Do NOT lower the delay below 3s without checking robots.txt and the host's
# acceptable-use posture. See README → "Data sources & ethics".
# ────────────────────────────────────────────────────────────────────────────
SCRAPER_USER_AGENT=fundamentals-ai/0.1 (+https://github.com/your-org/fundamentals-ai; educational demo)
SCRAPER_MIN_INTERVAL_SECONDS=3.0
SCRAPER_RESPECT_ROBOTS_TXT=true

# ────────────────────────────────────────────────────────────────────────────
# Cache TTLs (seconds). Documented strategy:
#   yfinance         → 6h
#   screener         → 24h
#   annual report    → indefinite (download once)
#   full agent run   → 12h per ticker
# ────────────────────────────────────────────────────────────────────────────
CACHE_TTL_YFINANCE_SECONDS=21600
CACHE_TTL_SCREENER_SECONDS=86400
CACHE_TTL_REPORT_SECONDS=43200

# ────────────────────────────────────────────────────────────────────────────
# Backend service config (FastAPI / uvicorn).
# ────────────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js). Inside docker-compose the backend is reachable at
# `http://backend:8000`; for browser-side WebSocket use the public URL.
# ────────────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
